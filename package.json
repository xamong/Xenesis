{
  "name": "xenesis-desk",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "AI agent with a workbench. Xenesis holds a 5-zone docking desktop and shares it with other AI agents through a Capability Registry, MCP bridge, and Gowoori UI rendering.",
  "main": "./out/main/index.js",
  "author": "Xamong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xamong/xenesis-desk.git"
  },
  "bugs": {
    "url": "https://github.com/xamong/xenesis-desk/issues"
  },
  "homepage": "https://github.com/xamong/xenesis-desk#readme",
  "keywords": [
    "ai-agent",
    "agent-workbench",
    "desktop",
    "electron",
    "mcp",
    "xcon",
    "workflow",
    "terminal-automation"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:electron": "electron-vite dev",
    "test": "node scripts/runRootTests.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "pack:win": "npm run build && electron-builder --win --x64 --dir",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:win:arm64": "npm run build && electron-builder --win --arm64",
    "pack:mac": "npm run build && electron-builder --mac --dir",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:universal": "npm run build && electron-builder --mac --universal",
    "dist:mac:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac --x64",
    "clean": "node ./scripts/clean.mjs",
    "docs:capabilities": "node ./scripts/generateCapabilityRegistryDocs.mjs",
    "docs:capabilities:audit": "node ./scripts/capabilityCoverageAudit.mjs",
    "check:docs-public": "node ./scripts/checkDocsPublicSafety.mjs",
    "check:public-release": "node ./scripts/publicReleaseCheck.mjs",
    "check:public-release:ci": "npm run check:public-release",
    "server": "node server/index.js",
    "server:dev": "cd server && npx nodemon index.js",
    "server:install": "cd server && npm install",
    "server:gowoori-sports": "node scripts/gowooriSportsToolsServer.mjs",
    "rebuild:server": "electron-rebuild -f -w better-sqlite3 -m ./server"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.73",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@duckdb/duckdb-wasm": "^1.33.1-dev45.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@lydell/node-pty": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@observablehq/plot": "^0.6.17",
    "@pomelo-suite/timeline": "^0.1.1",
    "@react-pdf/renderer": "^4.5.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/ssh2": "^1.15.5",
    "@uiw/react-codemirror": "^4.25.9",
    "@vscode/ripgrep": "^1.18.0",
    "@xcon-chain/core": "^0.1.1",
    "@xcon-viewer/core": "^0.1.7",
    "@xcon-viewer/viewer": "^0.1.7",
    "@xcon-workflow/core": "^0.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.208",
    "ajv": "^8.20.0",
    "apache-arrow": "^21.1.0",
    "basic-ftp": "^6.0.1",
    "chart.js": "^4.5.1",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "croner": "^10.0.1",
    "d3-array": "^3.2.4",
    "d3-chord": "^3.0.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.3",
    "graphql-request": "^7.4.0",
    "helmet": "^8.2.0",
    "hwp.js": "^0.0.3",
    "iconv-lite": "^0.7.2",
    "ink": "^7.1.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "leaflet.heat": "^0.2.0",
    "leaflet.markercluster": "^1.5.3",
    "mermaid": "^11.14.0",
    "mqtt": "^5.15.1",
    "openai": "^6.42.0",
    "pdfjs-dist": "^5.7.284",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.54.0",
    "pptxviewjs": "^1.1.9",
    "rate-limiter-flexible": "^11.2.0",
    "react": "19.2.7",
    "react-devtools-core": "^6.1.5",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.2.0",
    "ssh2": "^1.17.0",
    "xenesis": "file:packages/xenesis",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@electron/rebuild": "^4.0.4",
    "@types/d3-array": "^3.2.2",
    "@types/d3-chord": "^3.0.6",
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.xamong.xenesis.desk",
    "productName": "Xenesis Desk",
    "copyright": "Copyright © 2026 Xamong9",
    "toolsets": {
      "winCodeSign": "1.0.0"
    },
    "publish": {
      "provider": "github",
      "owner": "xamong",
      "repo": "xenesis-desk",
      "releaseType": "draft"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "node_modules/xenesis/**/*",
      "package.json",
      "src/main/xenisHome.mjs",
      "scripts/xd.mjs",
      "scripts/xenesisDeskSubagentHook.mjs",
      "mcp/**/*",
      "server/**/*",
      "extensions/sample.*/*",
      {
        "from": "packaging/extensions/xenesis-desk-bot",
        "to": "extensions/xenesis-desk.release-xenesis-bot",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "providers/hermes/plugins/xenesis_desk_gateway",
        "to": "provider-assets/hermes/plugins/xenesis_desk_gateway",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/*.test.*"
        ]
      },
      {
        "from": "providers/hermes/plugins/platforms/xenesis_desk_bot",
        "to": "provider-assets/hermes/plugins/platforms/xenesis_desk_bot",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/*.test.*"
        ]
      },
      {
        "from": "providers/shared/skills/xd",
        "to": "provider-assets/skills/xd",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/*.test.*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/**/*",
      "src/main/xenisHome.mjs",
      "scripts/xd.mjs",
      "scripts/xenesisDeskSubagentHook.mjs",
      "mcp/**/*",
      "server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Xenesis Desk",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable-${arch}.${ext}"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  }
}
